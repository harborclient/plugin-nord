{
  "name": "@harborclient/plugin-nord",
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "build": "esbuild src/renderer.tsx --bundle --outfile=dist/renderer.js --format=esm --external:react --external:react-dom && cp src/theme.css dist/theme.css",
    "dev": "esbuild src/renderer.tsx --bundle --outfile=dist/renderer.js --format=esm --external:react --external:react-dom --watch & cp src/theme.css dist/theme.css",
    "screenshot": "bash scripts/render-screenshot.sh",
    "pack": "pnpm build && zip -r ../nord.hcp manifest.json README.md assets dist",
    "plugin:sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "plugin:verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "dependencies": {
    "@harborclient/sdk": "^0.6.15"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "esbuild": "^0.25.0",
    "react": "^19.2.7",
    "typescript": "^5.0.0"
  }
}
